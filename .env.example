STORAGE_PROVIDER=r2

# Default R2 config used when no ?company=... is provided.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Company-specific R2 config. The frontend sends ?company=acme and the API
# resolves that to R2_ACME_* env vars after normalizing the company name.

R2_GLOBEX_BUCKET=
R2_GLOBEX_ACCESS_KEY_ID=
R2_GLOBEX_SECRET_ACCESS_KEY=
R2_GLOBEX_ENDPOINT=
R2_GLOBEX_PUBLIC_BASE_URL=
